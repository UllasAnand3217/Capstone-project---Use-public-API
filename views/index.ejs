<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Harry Potter API</title>
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>

    <h1>⚡ Harry Potter API Viewer</h1>

    <div class="btn-container">
        <form action="/spells" method="get">
            <button type="submit">Spells</button>
        </form>

        <form action="/characters" method="get">
            <button type="submit">All Characters</button>
        </form>
    </div>

    <div class="result">
            <p><%= locals.output %></p>
    </div>

</body>
</html>